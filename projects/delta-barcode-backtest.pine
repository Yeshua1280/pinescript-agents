// ╔═══════════════════════════════════════════════════════════════════════╗
// ║    DELTA BARCODE PRO V3 - STRATEGY BACKTEST OPTIMIZADO                ║
// ║              Yeshua Pro 3.0 - Anti-Whipsaw Edition                    ║
// ╠═══════════════════════════════════════════════════════════════════════╣
// ║ DIAGNÓSTICO DEL BACKTEST V1:                                          ║
// ║ • 54 trades, -$84.96 (-0.85%), Win Rate < 10%                        ║
// ║ • PROBLEMA 1: Overtrading (trades cada 5-15 min = whipsaw)           ║
// ║ • PROBLEMA 2: Sin filtro de tendencia (longs en caída)               ║
// ║ • PROBLEMA 3: Confirmación nula (entra al primer tick)               ║
// ║                                                                       ║
// ║ SOLUCIONES APLICADAS:                                                 ║
// ║ ✅ Filtro EMA tendencia (solo long si precio > EMA)                  ║
// ║ ✅ Cooldown entre trades (mín. N barras entre operaciones)           ║
// ║ ✅ Sesgo debe persistir N barras antes de entrar                     ║
// ║ ✅ Fuerza mínima requerida para entrar                               ║
// ║ ✅ Filtro ATR para evitar mercados sin volatilidad                   ║
// ║ ✅ Horario de trading configurable                                    ║
// ╠═══════════════════════════════════════════════════════════════════════╣
// ║ DISCLAIMER: Solo para fines educativos. No es asesoría financiera.   ║
// ╚═══════════════════════════════════════════════════════════════════════╝

//@version=6
strategy("Delta Barcode Backtest V2", "DB Backtest 3.1 Optimizado", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10, initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.1, slippage=2, pyramiding=0)

// ============================================================================
// INPUTS - MOTOR DELTA
// ============================================================================

var G_MAIN = "⚙️ Motor Delta"
history_len = input.int(50, "Profundidad Histórica", minval=10, maxval=200, group=G_MAIN)
lookback_fuerza = input.int(10, "Barras para Medir Fuerza", minval=3, maxval=50, group=G_MAIN)
use_volume_weight = input.bool(true, "Ponderar Delta por Volumen", group=G_MAIN)

// ============================================================================
// INPUTS - UMBRALES DE SESGO
// ============================================================================

var G_THRESH = "📊 Umbrales de Sesgo"
threshold_strong = input.float(0.4, "Umbral Fuerza Alcista", minval=0.05, maxval=1.0, step=0.05, group=G_THRESH)
threshold_weak = input.float(0.15, "Umbral Apagado", minval=0.0, maxval=0.5, step=0.05, group=G_THRESH)

// ============================================================================
// INPUTS - FILTROS ANTI-WHIPSAW (NUEVO)
// ============================================================================

var G_FILTER = "🛡️ Filtros Anti-Whipsaw"
use_ema_filter = input.bool(true, "Filtro EMA de Tendencia", group=G_FILTER,
     tooltip="Solo abre LONG si el precio está por encima de la EMA. Solo SHORT si está por debajo.")
ema_length = input.int(50, "Período EMA", minval=10, maxval=200, group=G_FILTER)

cooldown_bars = input.int(12, "Cooldown (barras entre trades)", minval=1, maxval=100, group=G_FILTER,
     tooltip="Número mínimo de barras que deben pasar entre una salida y la siguiente entrada. Evita overtrading.")

confirm_bars = input.int(3, "Confirmación (barras de sesgo estable)", minval=1, maxval=20, group=G_FILTER,
     tooltip="El sesgo debe mantenerse N barras consecutivas antes de abrir posición. Filtra señales falsas.")

min_force_entry = input.float(0.15, "Fuerza Mínima para Entrar", minval=0.0, maxval=0.5, step=0.05, group=G_FILTER,
     tooltip="La fuerza neta (compra-venta) debe ser mayor a este valor para confirmar entrada.")

use_atr_filter = input.bool(true, "Filtro ATR (volatilidad mínima)", group=G_FILTER,
     tooltip="No opera si la volatilidad es demasiado baja (mercado dormido).")
atr_min_mult = input.float(0.5, "Multiplicador ATR Mínimo", minval=0.1, maxval=3.0, step=0.1, group=G_FILTER,
     tooltip="ATR actual debe ser > ATR promedio × este multiplicador.")

// ============================================================================
// INPUTS – HORARIO DE TRADING (NUEVO)
// ============================================================================

var G_TIME = "🕐 Horario de Trading"
use_session = input.bool(false, "Activar Filtro de Horario", group=G_TIME,
     tooltip="Solo opera dentro del horario definido (útil para Forex/Futuros).")
session_start = input.int(8, "Hora Inicio (UTC)", minval=0, maxval=23, group=G_TIME)
session_end = input.int(20, "Hora Fin (UTC)", minval=0, maxval=23, group=G_TIME)

// ============================================================================
// INPUTS - GESTIÓN DE RIESGO
// ============================================================================

var G_RISK = "💰 Gestión de Riesgo"
use_sl = input.bool(true, "Usar Stop Loss", group=G_RISK)
sl_pct = input.float(2.0, "Stop Loss (%)", minval=0.5, maxval=20.0, step=0.5, group=G_RISK)
use_tp = input.bool(true, "Usar Take Profit", group=G_RISK)
tp_pct = input.float(4.0, "Take Profit (%)", minval=0.5, maxval=50.0, step=0.5, group=G_RISK)
allow_shorts = input.bool(false, "Permitir Shorts", group=G_RISK)
use_trailing = input.bool(false, "Usar Trailing Stop", group=G_RISK)
trail_pct = input.float(1.5, "Trailing Stop (%)", minval=0.5, maxval=10.0, step=0.5, group=G_RISK)

// ============================================================================
// INPUTS - VISUALIZACIÓN
// ============================================================================

var G_VIZ = "🎨 Visualización"
show_metrics = input.bool(true, "Mostrar Tabla de Métricas", group=G_VIZ)
metrics_position = input.string("Superior Derecha", "Posición de Métricas", group=G_VIZ,
     options=["Superior Izquierda", "Superior Centro", "Superior Derecha", "Inferior Izquierda", "Inferior Centro", "Inferior Derecha"])
metrics_size = input.string("Pequeño", "Tamaño de Métricas", group=G_VIZ,
     options=["Diminuto", "Pequeño", "Normal", "Grande"])
show_signals = input.bool(true, "Mostrar Señales en Gráfico", group=G_VIZ)
show_ema = input.bool(true, "Mostrar EMA en Gráfico", group=G_VIZ)
show_rejected = input.bool(false, "Mostrar Señales Rechazadas", group=G_VIZ,
     tooltip="Muestra con una X gris las señales que fueron filtradas.")

// ============================================================================
// VARIABLES
// ============================================================================

var float[] deltas_arr = array.new_float(0)
var string prev_sesgo = "NEUTRAL"
var int bars_since_exit = 999
var int bars_sesgo_estable = 0
var string last_sesgo_estable = "NEUTRAL"

// ============================================================================
// INDICADORES DE FILTRO
// ============================================================================

float ema_val = ta.ema(close, ema_length)
float atr_val = ta.atr(14)
float atr_avg = ta.sma(atr_val, 50)

// Sesión de trading
int hour_utc = hour(time, "UTC")
bool in_session = not use_session or (session_start < session_end ? (hour_utc >= session_start and hour_utc < session_end) : (hour_utc >= session_start or hour_utc < session_end))

// ============================================================================
// FUNCIÓN DE INTENSIDAD
// ============================================================================

f_fuerza(float[] sample, int barras) =>
    int sz = array.size(sample)
    if sz == 0
        [0.0, 0.0]
    else
        int n = math.min(barras, sz)
        float abs_max = 0.0
        for i = 0 to n - 1
            abs_max := math.max(abs_max, math.abs(array.get(sample, i)))
        if abs_max == 0
            [0.0, 0.0]
        else
            float buy_sum = 0.0
            float sell_sum = 0.0
            for i = 0 to n - 1
                float v = array.get(sample, i)
                float norm = math.abs(v) / abs_max
                if v > 0
                    buy_sum += norm
                else if v < 0
                    sell_sum += norm
            [buy_sum / n, sell_sum / n]

// ============================================================================
// MOTOR PRINCIPAL
// ============================================================================

string sesgo_actual = "NEUTRAL"
float buy_power = 0.0
float sell_power = 0.0
float net_force = 0.0

bool signal_long = false
bool signal_short = false
bool signal_close_long = false
bool signal_close_short = false
bool signal_rejected = false

// Incrementar cooldown
bars_since_exit += 1

if bar_index > history_len + 1

    // --- Calcular Deltas ---
    array.clear(deltas_arr)
    for i = 0 to history_len - 1
        float pc = close[i] - close[i + 1]
        float dv = use_volume_weight ? pc * volume[i] : pc
        array.push(deltas_arr, dv)

    // --- Fuerza ---
    [bp, sp] = f_fuerza(deltas_arr, lookback_fuerza)
    buy_power := bp
    sell_power := sp
    net_force := bp - sp

    // --- Contar rojas recientes ---
    int rojas = 0
    int sample_n = math.min(3, array.size(deltas_arr))
    for i = 0 to sample_n - 1
        if array.get(deltas_arr, i) < 0
            rojas += 1

    // --- Sesgo ---
    if bp >= threshold_strong
        sesgo_actual := "ALCISTA"
    else if bp <= threshold_weak and rojas >= 1
        sesgo_actual := "BAJISTA"

    // --- Contador de sesgo estable (NUEVO) ---
    if sesgo_actual == last_sesgo_estable
        bars_sesgo_estable += 1
    else
        bars_sesgo_estable := 1
        last_sesgo_estable := sesgo_actual

    // === FILTROS COMBINADOS ===
    bool ema_ok_long = not use_ema_filter or close > ema_val
    bool ema_ok_short = not use_ema_filter or close < ema_val
    bool cooldown_ok = bars_since_exit >= cooldown_bars
    bool confirm_ok = bars_sesgo_estable >= confirm_bars
    bool force_ok_long = net_force >= min_force_entry
    bool force_ok_short = net_force <= -min_force_entry
    bool atr_ok = not use_atr_filter or atr_val > atr_avg * atr_min_mult
    bool session_ok = in_session

    // --- Señales RAW ---
    bool raw_long = sesgo_actual == "ALCISTA" and prev_sesgo != "ALCISTA"
    bool raw_short = sesgo_actual == "BAJISTA" and prev_sesgo != "BAJISTA" and allow_shorts

    // --- Señales FILTRADAS ---
    if raw_long
        if ema_ok_long and cooldown_ok and confirm_ok and force_ok_long and atr_ok and session_ok
            signal_long := true
        else
            signal_rejected := true

    if raw_short
        if ema_ok_short and cooldown_ok and confirm_ok and force_ok_short and atr_ok and session_ok
            signal_short := true
        else
            signal_rejected := true

    // --- Cierres ---
    if strategy.position_size > 0 and sesgo_actual != "ALCISTA"
        signal_close_long := true

    if strategy.position_size < 0 and sesgo_actual != "BAJISTA"
        signal_close_short := true

    prev_sesgo := sesgo_actual

// ============================================================================
// EJECUCIÓN DE ÓRDENES
// ============================================================================

if signal_long
    strategy.entry("Long", strategy.long)

if signal_short
    strategy.entry("Short", strategy.short)

if signal_close_long
    strategy.close("Long", comment="Sesgo cambió")
    bars_since_exit := 0

if signal_close_short
    strategy.close("Short", comment="Sesgo cambió")
    bars_since_exit := 0

// --- SL / TP ---
if strategy.position_size > 0
    float ep = strategy.position_avg_price
    float sl_p = use_sl ? ep * (1 - sl_pct / 100) : na
    float tp_p = use_tp ? ep * (1 + tp_pct / 100) : na
    if use_trailing
        strategy.exit("Exit L", "Long", stop=sl_p, limit=tp_p, trail_points=close * trail_pct / 100 / syminfo.mintick, trail_offset=close * trail_pct / 100 / syminfo.mintick)
    else
        strategy.exit("Exit L", "Long", stop=sl_p, limit=tp_p)

if strategy.position_size < 0
    float ep = strategy.position_avg_price
    float sl_p = use_sl ? ep * (1 + sl_pct / 100) : na
    float tp_p = use_tp ? ep * (1 - tp_pct / 100) : na
    if use_trailing
        strategy.exit("Exit S", "Short", stop=sl_p, limit=tp_p, trail_points=close * trail_pct / 100 / syminfo.mintick, trail_offset=close * trail_pct / 100 / syminfo.mintick)
    else
        strategy.exit("Exit S", "Short", stop=sl_p, limit=tp_p)

// ============================================================================
// SEÑALES VISUALES
// ============================================================================

plotshape(show_signals and signal_long, "Long", shape.triangleup, location.belowbar, color.new(#2962FF, 0), size=size.small)
plotshape(show_signals and signal_short, "Short", shape.triangledown, location.abovebar, color.new(#FF1744, 0), size=size.small)
plotshape(show_signals and signal_close_long, "Close L", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny)
plotshape(show_signals and signal_close_short, "Close S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny)
plotshape(show_rejected and signal_rejected, "Rechazada", shape.xcross, location.belowbar, color.new(color.gray, 50), size=size.tiny)

// EMA
plot(show_ema and use_ema_filter ? ema_val : na, "EMA Filtro", color.new(color.orange, 30), 2)

// Color de barras
barcolor(sesgo_actual == "ALCISTA" ? color.new(#2962FF, 60) : sesgo_actual == "BAJISTA" ? color.new(#FF1744, 60) : na)

// ============================================================================
// TABLA DE MÉTRICAS
// ============================================================================

if show_metrics and barstate.islast
    string m_pos = switch metrics_position
        "Superior Izquierda" => position.top_left
        "Superior Centro" => position.top_center
        "Superior Derecha" => position.top_right
        "Inferior Izquierda" => position.bottom_left
        "Inferior Centro" => position.bottom_center
        "Inferior Derecha" => position.bottom_right
        => position.top_right

    string m_sz = switch metrics_size
        "Diminuto" => size.tiny
        "Pequeño" => size.small
        "Normal" => size.normal
        "Grande" => size.large
        => size.small

    var table mt = table.new(m_pos, 2, 14, bgcolor=color.new(#0a0a1a, 5), border_width=1, border_color=color.new(color.gray, 60))

    // Header
    table.cell(mt, 0, 0, "📊 BACKTEST V2", bgcolor=color.new(#16213e, 0), text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 0, "OPTIMIZADO", bgcolor=color.new(#16213e, 0), text_color=color.new(#26a69a, 0), text_size=m_sz)

    // Net Profit
    float net_profit = strategy.netprofit
    float net_pct = strategy.initial_capital > 0 ? (net_profit / strategy.initial_capital) * 100 : 0
    color profit_color = net_profit >= 0 ? color.new(#26a69a, 0) : color.new(#ef5350, 0)
    table.cell(mt, 0, 1, "Ganancia Neta", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 1, str.tostring(net_profit, "#,###.##") + " (" + str.tostring(net_pct, "#.##") + "%)", text_color=profit_color, text_size=m_sz)

    // Total Trades
    int total_trades = strategy.closedtrades
    table.cell(mt, 0, 2, "Total Trades", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 2, str.tostring(total_trades), text_color=color.yellow, text_size=m_sz)

    // Win Rate
    int wins = strategy.wintrades
    int losses = strategy.losstrades
    float win_rate = total_trades > 0 ? (wins / total_trades) * 100 : 0
    color wr_color = win_rate >= 50 ? color.new(#26a69a, 0) : color.new(#ef5350, 0)
    table.cell(mt, 0, 3, "Win Rate", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 3, str.tostring(win_rate, "#.##") + "% (" + str.tostring(wins) + "W/" + str.tostring(losses) + "L)", text_color=wr_color, text_size=m_sz)

    // Profit Factor
    float gp = strategy.grossprofit
    float gl = math.abs(strategy.grossloss)
    float pf = gl > 0 ? gp / gl : 0
    color pf_color = pf >= 1.5 ? color.new(#26a69a, 0) : pf >= 1.0 ? color.new(color.yellow, 0) : color.new(#ef5350, 0)
    table.cell(mt, 0, 4, "Profit Factor", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 4, str.tostring(pf, "#.##"), text_color=pf_color, text_size=m_sz)

    // Avg Win / Loss
    float avg_w = wins > 0 ? gp / wins : 0
    float avg_l = losses > 0 ? gl / losses : 0
    table.cell(mt, 0, 5, "Avg Win", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 5, str.tostring(avg_w, "#,###.##"), text_color=color.new(#26a69a, 0), text_size=m_sz)
    table.cell(mt, 0, 6, "Avg Loss", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 6, str.tostring(avg_l, "#,###.##"), text_color=color.new(#ef5350, 0), text_size=m_sz)

    // Max Drawdown
    var float max_eq = strategy.initial_capital
    var float max_dd = 0.0
    float ceq = strategy.equity
    if ceq > max_eq
        max_eq := ceq
    float dd = max_eq > 0 ? ((max_eq - ceq) / max_eq) * 100 : 0
    max_dd := math.max(max_dd, dd)
    color dd_color = max_dd < 10 ? color.new(#26a69a, 0) : max_dd < 25 ? color.new(color.yellow, 0) : color.new(#ef5350, 0)
    table.cell(mt, 0, 7, "Max Drawdown", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 7, str.tostring(max_dd, "#.##") + "%", text_color=dd_color, text_size=m_sz)

    // Avg per Trade
    float avg_trade = total_trades > 0 ? net_profit / total_trades : 0
    table.cell(mt, 0, 8, "Avg/Trade", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 8, str.tostring(avg_trade, "#,###.##"), text_color=avg_trade >= 0 ? color.new(#26a69a, 0) : color.new(#ef5350, 0), text_size=m_sz)

    // --- FILTROS ACTIVOS (para saber qué está encendido) ---
    string filtros = ""
    if use_ema_filter
        filtros += "EMA" + str.tostring(ema_length) + " "
    if cooldown_bars > 1
        filtros += "CD" + str.tostring(cooldown_bars) + " "
    if confirm_bars > 1
        filtros += "CF" + str.tostring(confirm_bars) + " "
    if use_atr_filter
        filtros += "ATR "
    if use_session
        filtros += "SES "
    table.cell(mt, 0, 9, "Filtros", text_color=color.new(color.gray, 30), text_size=m_sz)
    table.cell(mt, 1, 9, filtros, text_color=color.new(color.aqua, 0), text_size=m_sz)

    // Sesgo + Posición
    string se = sesgo_actual == "ALCISTA" ? "🟢" : sesgo_actual == "BAJISTA" ? "🔴" : "⚪"
    color sbg = sesgo_actual == "ALCISTA" ? color.new(#26a69a, 70) : sesgo_actual == "BAJISTA" ? color.new(#ef5350, 70) : color.new(color.gray, 80)
    table.cell(mt, 0, 10, "Sesgo", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 10, se + " " + sesgo_actual, text_color=color.white, bgcolor=sbg, text_size=m_sz)

    string pt = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    color pc = strategy.position_size > 0 ? color.new(#2962FF, 0) : strategy.position_size < 0 ? color.new(#FF1744, 0) : color.new(color.gray, 0)
    table.cell(mt, 0, 11, "Posición", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 11, pt, text_color=pc, text_size=m_sz)

    // Cooldown Status
    string cd_text = bars_since_exit >= cooldown_bars ? "✅ Listo" : "⏳ " + str.tostring(cooldown_bars - bars_since_exit) + " barras"
    table.cell(mt, 0, 12, "Cooldown", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 12, cd_text, text_color=bars_since_exit >= cooldown_bars ? color.new(#26a69a, 0) : color.new(color.orange, 0), text_size=m_sz)

    // Rating
    string rating = pf >= 2.0 and win_rate >= 55 ? "⭐⭐⭐⭐⭐" : pf >= 1.5 and win_rate >= 50 ? "⭐⭐⭐⭐" : pf >= 1.0 ? "⭐⭐⭐" : pf > 0 ? "⭐⭐" : "⭐"
    color rc = pf >= 1.5 ? color.new(#26a69a, 0) : pf >= 1.0 ? color.new(color.yellow, 0) : color.new(#ef5350, 0)
    table.cell(mt, 0, 13, "Rating", text_color=color.white, text_size=m_sz)
    table.cell(mt, 1, 13, rating, text_color=rc, bgcolor=color.new(#16213e, 0), text_size=m_sz)
